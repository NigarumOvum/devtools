---
import Layout from "../layouts/Layout.astro";
import { getSession } from "auth-astro/server";
import { StudioSection } from "../components/StudioSection";
import { getLangFromUrl, useTranslations } from "../utils/i18n";

const session = await getSession(Astro.request);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("aiStudio.pageTitle")}>
    <main class="min-h-screen pt-20 md:pl-72 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <!-- Breadcrumbs -->
            <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
                <a href="/" class="hover:text-blue-500 transition-colors">
                    {t("aiStudio.breadcrumbHome")}
                </a>
                <span>/</span>
                <span class="text-slate-900 dark:text-white font-semibold">
                    {t("aiStudio.breadcrumbStudio")}
                </span>
            </nav>

            <StudioSection client:load initialSession={session} lang={lang} />
        </div>
    </main>
</Layout>
